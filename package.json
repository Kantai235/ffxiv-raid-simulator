{
  "name": "ffxiv-raid-simulator",
  "private": true,
  "version": "0.0.1",
  "description": "FFXIV 高難度副本（零式/絕本）機制模擬練習器 - Monorepo 根",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:player": "npm run dev --workspace=@ffxiv-sim/player",
    "dev:editor": "npm run dev --workspace=@ffxiv-sim/editor",
    "build:player": "npm run build --workspace=@ffxiv-sim/player",
    "build:editor": "npm run build --workspace=@ffxiv-sim/editor",
    "build:shared": "npm run build --workspace=@ffxiv-sim/shared",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write \"**/*.{ts,vue,json,md}\"",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
